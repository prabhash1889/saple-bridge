# Normalize line endings to LF for text files to stop CRLF churn on Windows
# (e.g. recurring "LF will be replaced by CRLF" on Cargo.toml / *.css).
* text=auto eol=lf

# Explicit LF for code and config that must stay LF cross-platform
*.rs      text eol=lf
*.toml    text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.md      text eol=lf
*.py      text eol=lf
*.html    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf

# Binary assets — never normalize
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.icns    binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.wav     binary
*.mp3     binary
